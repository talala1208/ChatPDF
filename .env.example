# 项目根目录环境变量（Web 后端共用）
# 复制为 .env 并填入真实密钥

DASHSCOPE_API_KEY=your_dashscope_api_key_here
# 建库路由: per_page（按页切块）| full_text（全书切块+start_index，默认）
# BUILD_ROUTE=full_text

# Python 环境（可选，使用 conda 时）
# CONDA_ENV=ai_env

# MinerU 云端 API（PDF 解析，Token 见 https://mineru.net）
MINERU_API_KEY=your_mineru_api_token_here
# MINERU_API_BASE=https://mineru.net/api/v4
# MINERU_MODEL_VERSION=pipeline
# MINERU_IS_OCR=true
# MINERU_ENABLE_FORMULA=false
# MINERU_ENABLE_TABLE=true
# MINERU_LANG=ch
# MINERU_POLL_INTERVAL=5
# MINERU_TIMEOUT=600
# MINERU_DOWNLOAD_RETRIES=5
# MinerU 原始结果（zip + 解压）保存目录，默认 web/data/mineru_output
# MINERU_OUTPUT_DIR=web/data/mineru_output
# 建库 chunks 调试 Markdown 汇总目录，默认 web/data/chunk_debug
# CHUNK_DEBUG_DIR=web/data/chunk_debug
# MinerU CDN 下载会绕过系统代理（代理易导致 cdn-mineru SSL 失败）
